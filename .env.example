# Copy to .env and adjust for anything beyond local testing -
# docker-compose.yml has working defaults for everything below, so
# `docker-compose up` works without this file.

# Session-signing secret. Change this for anything beyond local testing.
WEB_SESSION_SECRET=dev-only-change-me

# Sole in-memory admin account. Default: admin / admin.
WEB_ADMIN_USERNAME=admin
# sha256 hex digest of the password - e.g. `printf '%s' 'your-password' | sha256sum`
WEB_ADMIN_PASSWORD_SHA256=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918
